# Port on which the Node.js Express server will run
PORT=5000

# Cloudinary configuration (found on your Cloudinary dashboard)
# Cloud Name: The unique identifier of your Cloudinary cloud account
CLOUDINARY_CLOUD_NAME=dwhee5w49
# API Key: Public key for authentication
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
# API Secret: Private secret key (keep secure, never commit to git)
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Path to your Firebase service account private key JSON file.
# You can generate this file from: Firebase Console > Project Settings > Service accounts > "Generate new private key".
# Download and rename it to 'firebase-service-account.json' and place it in the '/backend' directory.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
